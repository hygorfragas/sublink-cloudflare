{
  "name": "n8n-nodes-cloudflare-link-shortener",
  "version": "0.1.0",
  "description": "n8n community node — gerencia links curtos em Cloudflare Workers KV (API REST).",
  "keywords": [
    "n8n-community-node-package",
    "cloudflare",
    "kv",
    "shortener",
    "links"
  ],
  "license": "MIT",
  "homepage": "https://github.com/hygorfragas/sublink-cloudflare",
  "author": {
    "name": "Hygor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hygorfragas/sublink-cloudflare.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CloudflareKvShortenerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CloudflareLinkShortener/CloudflareLinkShortener.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "n8n-workflow": "^1.82.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.60.0"
  }
}
